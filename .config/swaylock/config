# swaylock Konfiguration
# Arch Linux Lockscreen

# Hintergrund
image=~/.config/swaylock/lockscreen.png
# Falls kein Bild gewünscht, stattdessen Farbe nutzen:
# color=1e1e2e

# Effekte
scaling=fill
ignore-empty-password

# Indikator
indicator-radius=120
indicator-thickness=10
indicator-caps-lock

# Farben (Catppuccin Mocha Theme)
inside-color=1e1e2ebb
inside-clear-color=1e1e2ebb
inside-caps-lock-color=1e1e2ebb
inside-ver-color=1e1e2ebb
inside-wrong-color=1e1e2ebb

ring-color=cba6f7
ring-clear-color=a6e3a1
ring-caps-lock-color=fab387
ring-ver-color=89b4fa
ring-wrong-color=f38ba8

key-hl-color=cba6f7
bs-hl-color=f38ba8
caps-lock-key-hl-color=fab387
caps-lock-bs-hl-color=f38ba8

text-color=cdd6f4
text-clear-color=a6e3a1
text-caps-lock-color=fab387
text-ver-color=89b4fa
text-wrong-color=f38ba8

line-color=00000000
line-clear-color=00000000
line-caps-lock-color=00000000
line-ver-color=00000000
line-wrong-color=00000000

separator-color=00000000

# Layout
font=JetBrainsMono Nerd Font
font-size=20
